package com.pedrowillianrocha68stack.dto;

import jakarta.validation.constraints.*;

public record LivroRequestDTO(

    @NotBlank(message = "Título obrigatório")
    @Size(max = 150, message = "Título deve ter no máximo 150 caracteres")
    String titulo,

    @NotBlank(message = "Autor obrigatório")
    @Size(max = 100, message = "Autor deve ter no máximo 100 caracteres")
    String autor,

    @NotBlank(message = "ISBN obrigatório")
    String isbn,

    @Min(value = 1000, message = "Ano de publicação inválido")
    @Max(value = 2100, message = "Ano de publicação inválido")
    int anoPublicacao,

    @NotBlank(message = "Categoria obrigatória")
    String categoria

) {}
